// FatooraLite data model — PostgreSQL (Supabase in production).
// Local dev: run `docker compose up -d` for a local Postgres, or point
// DATABASE_URL/DIRECT_URL at a Supabase project. Migrations use DIRECT_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  nameAr    String?
  vatNumber String   @unique
  crNumber  String?
  address   String?
  createdAt DateTime @default(now())

  branches     Branch[]
  certificates Certificate[]
  invoices     Invoice[]
  users        User[]
  customers    Customer[]
  products     Product[]
  notifications Notification[]
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  nameAr    String?
  city      String?
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]
}

model Certificate {
  id          String    @id @default(cuid())
  companyId   String
  kind        String // "compliance" | "production"
  serial      String?
  csrPem      String?
  privateKey  String? // EC private key PEM (encrypt at rest in production)
  publicKey   String? // EC public key PEM (used for the QR public key)
  certificate String? // decoded issued certificate PEM, if available
  token       String? // ZATCA binarySecurityToken (CSID certificate, base64)
  secret      String? // ZATCA CSID secret
  requestId   String? // ZATCA request id
  status      String    @default("pending") // pending|compliance|active|expired|failed
  issuedAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String?
  customerId    String?
  invoiceNumber String
  uuid          String   @unique
  kind          String // standard | simplified
  documentType  String   @default("invoice")
  status        String   @default("draft") // draft|signed|submitted|cleared|reported|rejected
  issueDate     String
  issueTime     String   @default("00:00:00")
  buyerName     String?
  buyerVat      String?
  taxableAmount Float    @default(0)
  vatAmount     Float    @default(0)
  grandTotal    Float    @default(0)
  xml           String?
  signedXml     String?
  hash          String?
  previousHash  String?
  signature     String?
  qr            String?
  resultCode    String? // e.g. BR-KSA-83 on rejection
  createdAt     DateTime @default(now())

  company  Company          @relation(fields: [companyId], references: [id])
  branch   Branch?          @relation(fields: [branchId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  lines    InvoiceLine[]
  records  ClearanceRecord[]
  audit    AuditEntry[]

  @@unique([companyId, invoiceNumber])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float   @default(0.15)
  netAmount   Float
  vatAmount   Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ClearanceRecord {
  id           String   @id @default(cuid())
  invoiceId    String
  action       String // clearance | reporting
  status       String // accepted | rejected | warning | pending
  responseCode String?
  message      String?
  rawResponse  String?
  createdAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model AuditEntry {
  id        String   @id @default(cuid())
  invoiceId String?
  kind      String // xml | signedXml | qr | apiResponse | event
  payload   String
  createdAt DateTime @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model User {
  id           String   @id @default(cuid())
  companyId    String?
  email        String   @unique
  name         String
  role         String   @default("employee") // owner|accountant|manager|auditor|employee
  passwordHash String?
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  nameAr    String?
  vatNumber String?
  crNumber  String?
  address   String?
  city      String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  nameAr      String?
  sku         String?
  unitPrice   Float
  vatCategory String   @default("S") // S, Z, E, O
  unitCode    String   @default("PCE")
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  title     String
  message   String
  type      String   @default("info") // info|warning|error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id])
}
