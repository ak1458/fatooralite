# ---- Database (PostgreSQL) ----
# Local dev: `docker compose up -d` then use the local URL below.
DATABASE_URL="postgresql://fatoora:fatoora@localhost:5432/fatooralite?schema=public"
DIRECT_URL="postgresql://fatoora:fatoora@localhost:5432/fatooralite?schema=public"
#
# Supabase: Project Settings → Database → Connection string.
#   DATABASE_URL = the *pooled* (Transaction) URL, port 6543, add ?pgbouncer=true
#   DIRECT_URL   = the *direct* URL, port 5432 (used for migrations)
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Generate a long random value in production, e.g. `openssl rand -base64 48`.
AUTH_SECRET="dev-insecure-secret-change-me-1234567890"
# Require login + RBAC on every page (off by default for local dev).
# AUTH_ENFORCE=true

# ---- ZATCA Fatoora gateway ----
ZATCA_MODE="sandbox"            # sandbox | production
ZATCA_SANDBOX_BASE_URL="https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal"
ZATCA_PRODUCTION_BASE_URL="https://gw-fatoora.zatca.gov.sa/e-invoicing/core"

# ---- Tests ----
# Set to a disposable Postgres to run DB integration tests (skipped otherwise):
# TEST_DATABASE_URL="postgresql://fatoora:fatoora@localhost:5432/fatooralite_test?schema=public"
