# ---- Database (PostgreSQL) ----
# DATABASE_URL = pooled connection (app runtime); DIRECT_URL = direct (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
#
# Neon (free tier): Console → Connection Details.
#   DATABASE_URL = the *pooled* host (…-pooler…), add ?sslmode=require&pgbouncer=true
#   DIRECT_URL   = the *direct* host, ?sslmode=require (used for migrations)
# Local Postgres / Supabase work the same way — point both URLs at your instance.

# ---- Auth ----
# Generate a long random value in production, e.g. `openssl rand -base64 48`.
AUTH_SECRET="dev-insecure-secret-change-me-1234567890"
# Require login + RBAC on every page (off by default for local dev).
# AUTH_ENFORCE=true

# ---- ZATCA Fatoora gateway ----
ZATCA_MODE="sandbox"            # sandbox | production
ZATCA_SANDBOX_BASE_URL="https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal"
ZATCA_PRODUCTION_BASE_URL="https://gw-fatoora.zatca.gov.sa/e-invoicing/core"

# ---- AI assistant (OpenRouter — free models) ----
# Get a key at https://openrouter.ai/keys. Without it the assistant and AI
# insights run in a safe mock/deterministic mode (no external calls).
# OPENROUTER_API_KEY="sk-or-v1-..."
# Free models (override as you like). Fallback is tried if the primary is busy.
# gpt-oss returns answers reliably; nemotron-nano is also free but spends its
# budget on hidden reasoning, so it's not the default. Set it here if you want it.
# OPENROUTER_MODEL="openai/gpt-oss-120b:free"
# OPENROUTER_FALLBACK_MODEL="openai/gpt-oss-20b:free"

# ---- Tests ----
# Set to a disposable Postgres to run DB integration tests (skipped otherwise):
# TEST_DATABASE_URL="postgresql://fatoora:fatoora@localhost:5432/fatooralite_test?schema=public"
